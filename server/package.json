{
  "name": "yt-knowledge-base-server",
  "version": "0.1.0",
  "private": true,
  "description": "Strapi backend for the YouTube knowledge base app.",
  "scripts": {
    "build": "strapi build",
    "console": "strapi console",
    "deploy": "strapi deploy",
    "dev": "strapi develop",
    "develop": "strapi develop",
    "start": "strapi start",
    "strapi": "strapi",
    "export": "strapi export --no-encrypt --file ./seed-data/seed",
    "seed": "strapi import --file ./seed-data/seed.tar.gz",
    "upgrade": "npx @strapi/upgrade latest",
    "upgrade:dry": "npx @strapi/upgrade latest --dry"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@strapi/plugin-cloud": "5.42.0",
    "@strapi/plugin-users-permissions": "5.42.0",
    "@strapi/strapi": "5.42.0",
    "better-sqlite3": "12.8.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "youtubei.js": "^17.0.1",
    "zod": "^4.3.5",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": false
  }
}
