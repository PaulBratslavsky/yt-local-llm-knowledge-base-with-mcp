{
  "kind": "collectionType",
  "collectionName": "tags",
  "info": {
    "singularName": "tag",
    "pluralName": "tags",
    "displayName": "Tag",
    "description": "Free-form tag on a Post. Created on the fly at post time. Server-side normalization keeps `name` lowercase-trimmed so dedupe works."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "minLength": 1,
      "maxLength": 40
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "videos": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::video.video",
      "mappedBy": "tags"
    }
  }
}
